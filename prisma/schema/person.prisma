model Person {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  description String?
  birthday    DateTime?
  age         Int?
  phoneNumber String?
  address     Address?
  user        User?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("persons")
}

type Address {
  street       String?
  barangay     String?
  city         String?
  municipality String?
  province     String?
  postalCode   String?
}
